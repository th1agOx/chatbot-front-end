{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "esnext",
    "target": "es2023",
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "erasableSyntaxOnly": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["jest", "node", "vite/client"]
  },
  "include": ["src"]
}
